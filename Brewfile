# Dependencies for the my_config dev toolkit (functions.zsh)
# Install everything with:  brew bundle --file=Brewfile

brew "fzf"        # fuzzy finder — the engine behind ff / fa / ffg / gg / gc
brew "ripgrep"    # rg — interactive content search (fa)
brew "bat"        # syntax-highlighted previews + the `cat` alias
brew "eza"        # modern ls (ls / ll / la / lt)
brew "fd"         # fast file find
brew "gh"         # GitHub CLI — PR list in gg, and this installer
brew "git-delta"  # prettier diffs in gg (falls back to plain if absent)

# VS Code provides the `code` CLI that ff / fa use to open files
cask "visual-studio-code"
